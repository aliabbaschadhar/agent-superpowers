{
  "name": "agent-superpowers",
  "displayName": "AI Agent Superpowers",
  "description": "Browse, preview, and install 940+ AI agent skills for GitHub Copilot, Cursor, Windsurf and AntiGravity.",
  "version": "1.0.0",
  "publisher": "aliabbaschadhar",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/aliabbaschadhar/agent-superpowers"
  },
  "homepage": "https://github.com/aliabbaschadhar/agent-superpowers#readme",
  "bugs": {
    "url": "https://github.com/aliabbaschadhar/agent-superpowers/issues"
  },
  "keywords": [
    "cursor",
    "copilot",
    "ai-skills",
    "agentic",
    "skill-picker",
    "llm",
    "ai-agent"
  ],
  "categories": [
    "AI",
    "Other",
    "Snippets"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "aiSkills.browse",
        "title": "Browse & Copy Skill ID",
        "category": "AI Skills"
      },
      {
        "command": "aiSkills.install",
        "title": "Install Skill",
        "category": "AI Skills"
      },
      {
        "command": "aiSkills.uninstall",
        "title": "Uninstall Skill",
        "category": "AI Skills",
        "icon": "$(trash)"
      },
      {
        "command": "aiSkills.uninstallCategory",
        "title": "Uninstall All in Category",
        "category": "AI Skills",
        "icon": "$(trash)"
      },
      {
        "command": "aiSkills.uninstallCollection",
        "title": "Uninstall Collection",
        "category": "AI Skills",
        "icon": "$(trash)"
      },
      {
        "command": "aiSkills.uninstallAll",
        "title": "Uninstall All Installed Skills",
        "category": "AI Skills",
        "icon": "$(trash)"
      },
      {
        "command": "aiSkills.preview",
        "title": "Preview Skill Content",
        "category": "AI Skills",
        "icon": "$(eye)"
      },
      {
        "command": "aiSkills.copyId",
        "title": "Copy Skill ID",
        "category": "AI Skills",
        "icon": "$(clippy)"
      },
      {
        "command": "aiSkills.installFromTree",
        "title": "Install from Sidebar",
        "category": "AI Skills",
        "icon": "$(cloud-download)"
      },
      {
        "command": "aiSkills.refreshTree",
        "title": "Refresh Skills Tree",
        "category": "AI Skills",
        "icon": "$(refresh)"
      },
      {
        "command": "aiSkills.bulkCopy",
        "title": "Bulk Copy Skill IDs to Clipboard",
        "category": "AI Skills",
        "icon": "$(copy)"
      },
      {
        "command": "aiSkills.installCategory",
        "title": "Install All in Category",
        "category": "AI Skills",
        "icon": "$(cloud-download)"
      },
      {
        "command": "aiSkills.installAll",
        "title": "Install All Skills",
        "category": "AI Skills",
        "icon": "$(cloud-download)"
      },
      {
        "command": "aiSkills.installCollection",
        "title": "Install Collection",
        "category": "AI Skills",
        "icon": "$(cloud-download)"
      },
      {
        "command": "aiSkills.filterTree",
        "title": "Show Installed Skills Only",
        "category": "AI Skills",
        "icon": "$(filter)"
      },
      {
        "command": "aiSkills.browseCollections",
        "title": "Browse Skill Collections",
        "category": "AI Skills",
        "icon": "$(package)"
      },
      {
        "command": "aiSkills.createSkill",
        "title": "Create New Skill",
        "category": "AI Skills",
        "icon": "$(add)"
      },
      {
        "command": "aiSkills.exportSkillSet",
        "title": "Export Installed Skills as Set",
        "category": "AI Skills",
        "icon": "$(export)"
      },
      {
        "command": "aiSkills.showWelcome",
        "title": "Show Welcome Message",
        "category": "AI Skills"
      },
      {
        "command": "aiSkills.importSkillSet",
        "title": "Import Skill Set from File",
        "category": "AI Skills",
        "icon": "$(import)"
      },
      {
        "command": "aiSkills.toggleFavorite",
        "title": "Toggle Favorite",
        "category": "AI Skills",
        "icon": "$(star)"
      },
      {
        "command": "aiSkills.clearFavorites",
        "title": "Clear All Favorites",
        "category": "AI Skills",
        "icon": "$(star-delete)"
      },
      {
        "command": "aiSkills.createCollection",
        "title": "New Custom Collection",
        "category": "AI Skills",
        "icon": "$(add)"
      },
      {
        "command": "aiSkills.editCollection",
        "title": "Edit Collection",
        "category": "AI Skills",
        "icon": "$(edit)"
      },
      {
        "command": "aiSkills.deleteCollection",
        "title": "Delete Collection",
        "category": "AI Skills",
        "icon": "$(trash)"
      },
      {
        "command": "aiSkills.addToCollection",
        "title": "Add to Collection",
        "category": "AI Skills",
        "icon": "$(list-ordered)"
      },
      {
        "command": "aiSkills.removeFromCollection",
        "title": "Remove from Collection",
        "category": "AI Skills",
        "icon": "$(remove)"
      },
      {
        "command": "aiSkills.updateAll",
        "title": "Update All Installed Skills",
        "category": "AI Skills",
        "icon": "$(sync)"
      },
      {
        "command": "aiSkills.refreshCatalog",
        "title": "Refresh Skills Catalog",
        "category": "AI Skills",
        "icon": "$(list-unordered)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiSkillsContainer",
          "title": "AI Agent Skills",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "aiSkillsContainer": [
        {
          "id": "aiSkillsTree",
          "name": "Skills",
          "type": "tree",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "aiSkills.filterTree",
          "when": "view == aiSkillsTree && !aiSkills.installedFilterActive",
          "group": "navigation@0"
        },
        {
          "command": "aiSkills.filterTree",
          "when": "view == aiSkillsTree && aiSkills.installedFilterActive",
          "group": "navigation@0"
        },
        {
          "command": "aiSkills.bulkCopy",
          "when": "view == aiSkillsTree",
          "group": "navigation@1"
        },
        {
          "command": "aiSkills.refreshTree",
          "when": "view == aiSkillsTree",
          "group": "navigation@2"
        },
        {
          "command": "aiSkills.installAll",
          "when": "view == aiSkillsTree",
          "group": "navigation@3"
        },
        {
          "command": "aiSkills.browseCollections",
          "when": "view == aiSkillsTree",
          "group": "2_collections@1"
        },
        {
          "command": "aiSkills.createSkill",
          "when": "view == aiSkillsTree",
          "group": "2_collections@2"
        },
        {
          "command": "aiSkills.createCollection",
          "when": "view == aiSkillsTree",
          "group": "2_collections@3"
        },
        {
          "command": "aiSkills.exportSkillSet",
          "when": "view == aiSkillsTree",
          "group": "3_importexport@1"
        },
        {
          "command": "aiSkills.importSkillSet",
          "when": "view == aiSkillsTree",
          "group": "3_importexport@2"
        },
        {
          "command": "aiSkills.updateAll",
          "when": "view == aiSkillsTree && aiSkills.updatesAvailable",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "aiSkills.preview",
          "when": "view == aiSkillsTree && viewItem =~ /^skill(\\.favorited)?$/",
          "group": "inline@1"
        },
        {
          "command": "aiSkills.copyId",
          "when": "view == aiSkillsTree && viewItem =~ /^skill(\\.favorited)?$/",
          "group": "inline@2"
        },
        {
          "command": "aiSkills.installFromTree",
          "when": "view == aiSkillsTree && viewItem =~ /^skill(\\.favorited)?$/",
          "group": "inline@3"
        },
        {
          "command": "aiSkills.toggleFavorite",
          "when": "view == aiSkillsTree && viewItem =~ /^skill(\\.favorited)?$/",
          "group": "inline@4"
        },
        {
          "command": "aiSkills.addToCollection",
          "when": "view == aiSkillsTree && viewItem =~ /^skill/",
          "group": "context@1"
        },
        {
          "command": "aiSkills.preview",
          "when": "view == aiSkillsTree && viewItem =~ /^skill-installed/",
          "group": "inline@1"
        },
        {
          "command": "aiSkills.copyId",
          "when": "view == aiSkillsTree && viewItem =~ /^skill-installed/",
          "group": "inline@2"
        },
        {
          "command": "aiSkills.toggleFavorite",
          "when": "view == aiSkillsTree && viewItem =~ /^skill-installed/",
          "group": "inline@4"
        },
        {
          "command": "aiSkills.uninstall",
          "when": "view == aiSkillsTree && viewItem =~ /^skill-installed/",
          "group": "inline@3"
        },
        {
          "command": "aiSkills.installCategory",
          "when": "view == aiSkillsTree && viewItem == category",
          "group": "inline@1"
        },
        {
          "command": "aiSkills.uninstallCategory",
          "when": "view == aiSkillsTree && viewItem == category.installed",
          "group": "inline@1"
        },
        {
          "command": "aiSkills.installCategory",
          "when": "view == aiSkillsTree && viewItem == allCategories",
          "group": "inline@1"
        },
        {
          "command": "aiSkills.installCollection",
          "when": "view == aiSkillsTree && viewItem == collection",
          "group": "inline@1"
        },
        {
          "command": "aiSkills.uninstallCollection",
          "when": "view == aiSkillsTree && viewItem == collection.installed",
          "group": "inline@1"
        },
        {
          "command": "aiSkills.installAll",
          "when": "view == aiSkillsTree && viewItem == summary",
          "group": "inline@1"
        },
        {
          "command": "aiSkills.uninstallAll",
          "when": "view == aiSkillsTree && viewItem == installedSection",
          "group": "inline@1"
        },
        {
          "command": "aiSkills.clearFavorites",
          "when": "view == aiSkillsTree && viewItem == favoritesCategory",
          "group": "inline@1"
        },
        {
          "command": "aiSkills.installCollection",
          "when": "view == aiSkillsTree && viewItem == recommended",
          "group": "inline@1"
        },
        {
          "command": "aiSkills.preview",
          "when": "view == aiSkillsTree && viewItem =~ /^skill-recommended/",
          "group": "inline@1"
        },
        {
          "command": "aiSkills.copyId",
          "when": "view == aiSkillsTree && viewItem =~ /^skill-recommended/",
          "group": "inline@2"
        },
        {
          "command": "aiSkills.installFromTree",
          "when": "view == aiSkillsTree && viewItem =~ /^skill-recommended(?!.*\\.installed)/",
          "group": "inline@3"
        },
        {
          "command": "aiSkills.uninstall",
          "when": "view == aiSkillsTree && viewItem =~ /^skill-recommended.*\\.installed/",
          "group": "inline@3"
        },
        {
          "command": "aiSkills.toggleFavorite",
          "when": "view == aiSkillsTree && viewItem =~ /^skill-recommended/",
          "group": "inline@4"
        },
        {
          "command": "aiSkills.editCollection",
          "when": "view == aiSkillsTree && viewItem == user-collection",
          "group": "inline@1"
        },
        {
          "command": "aiSkills.deleteCollection",
          "when": "view == aiSkillsTree && viewItem == user-collection",
          "group": "inline@2"
        },
        {
          "command": "aiSkills.installCollection",
          "when": "view == aiSkillsTree && viewItem == user-collection",
          "group": "inline@3"
        },
        {
          "command": "aiSkills.uninstallCollection",
          "when": "view == aiSkillsTree && viewItem == user-collection.installed",
          "group": "inline@3"
        }
      ]
    },
    "keybindings": [
      {
        "command": "aiSkills.browse",
        "key": "ctrl+shift+/",
        "mac": "cmd+shift+/"
      }
    ],
    "languageModelTools": [
      {
        "name": "aiSkills_requestSkill",
        "displayName": "AI Skills: Request Skill",
        "modelDescription": "Installs and retrieves an AI agent skill from the catalog by its kebab-case ID. Call this tool when you need domain-specific knowledge that a skill provides (e.g. react-patterns for React, api-design-principles for REST APIs, ai-agents-architect for agent design). Pass the exact skill ID. Returns the full SKILL.md content to use in your response. Do NOT call this for skills already in context.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "requestSkill",
        "inputSchema": {
          "type": "object",
          "properties": {
            "skillId": {
              "type": "string",
              "description": "The kebab-case skill ID from the catalog, e.g. \"react-patterns\" or \"api-design-principles\"."
            }
          },
          "required": [
            "skillId"
          ]
        }
      },
      {
        "name": "aiSkills_listInstalled",
        "displayName": "AI Skills: List Installed Skills",
        "modelDescription": "Lists all installed AI agent skills with their metadata. Use this to discover what skills are already available in the current workspace. Optionally filter by category or limit results.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "listInstalled",
        "inputSchema": {
          "type": "object",
          "properties": {
            "category": {
              "type": "string",
              "description": "Optional category filter (e.g. \"react-patterns\", \"api-design\"). Returns only skills in this category."
            },
            "limit": {
              "type": "number",
              "description": "Maximum number of skills to return. Default: 100"
            }
          }
        }
      },
      {
        "name": "aiSkills_searchSkills",
        "displayName": "AI Skills: Search Skills",
        "modelDescription": "Searches the AI skills catalog by keyword using fuzzy matching. Returns skills matching the query with installation status. Use this to discover relevant skills before installing them.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "searchSkills",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query - matches against skill names, descriptions, and categories."
            },
            "category": {
              "type": "string",
              "description": "Optional category filter to narrow results."
            },
            "limit": {
              "type": "number",
              "description": "Maximum results to return. Default: 20"
            },
            "includeInstalled": {
              "type": "boolean",
              "description": "Whether to include installation status. Default: true"
            }
          },
          "required": [
            "query"
          ]
        }
      },
      {
        "name": "aiSkills_getSkillInfo",
        "displayName": "AI Skills: Get Skill Info",
        "modelDescription": "Retrieves metadata and optional preview for a specific skill without installing it. Use this to get skill details like category, risk level, and description before deciding to install.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "getSkillInfo",
        "inputSchema": {
          "type": "object",
          "properties": {
            "skillId": {
              "type": "string",
              "description": "The skill ID to retrieve information for, e.g. \"react-patterns\"."
            },
            "includePreview": {
              "type": "boolean",
              "description": "Include full skill content preview (only if installed). Default: false"
            }
          },
          "required": [
            "skillId"
          ]
        }
      },
      {
        "name": "aiSkills_checkUpdates",
        "displayName": "AI Skills: Check for Updates",
        "modelDescription": "Checks installed skills for available updates by comparing content hashes. Call this to determine if any installed skills have newer versions available in the catalog.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "checkUpdates",
        "inputSchema": {
          "type": "object",
          "properties": {
            "skillId": {
              "type": "string",
              "description": "Optional specific skill ID to check. If omitted, checks all installed skills."
            }
          }
        }
      },
      {
        "name": "aiSkills_batchInstall",
        "displayName": "AI Skills: Batch Install",
        "modelDescription": "Installs multiple AI skills in a single operation. Provide an array of skill IDs or a category name to install all skills in that category. Useful for setting up a complete skill set for a project.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "batchInstall",
        "inputSchema": {
          "type": "object",
          "properties": {
            "skillIds": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Array of skill IDs to install, e.g. [\"react-patterns\", \"typescript-best-practices\"]."
            },
            "category": {
              "type": "string",
              "description": "Install all skills in a category. If provided, overrides skillIds."
            },
            "overwrite": {
              "type": "boolean",
              "description": "Overwrite existing skills without prompting. Default: false"
            }
          }
        }
      }
    ],
    "configuration": {
      "title": "AI Agent Skills",
      "properties": {
        "aiSkills.confirmOverwrite": {
          "type": "boolean",
          "default": true,
          "description": "Ask before overwriting an already-installed skill file."
        },
        "aiSkills.showRiskBadge": {
          "type": "boolean",
          "default": true,
          "description": "Show a risk-level badge (safe / unknown) next to each skill in the Browse QuickPick and sidebar tooltip."
        },
        "aiSkills.localSkillsPath": {
          "type": "string",
          "default": "",
          "description": "Path to a local folder of custom skills (e.g. ~/my-ai-rules/). Each subfolder containing a SKILL.md is treated as a skill."
        },
        "aiSkills.remoteIndexUrl": {
          "type": "string",
          "default": "",
          "description": "Override the remote skills index URL (GitHub raw URL or Gist). Leave empty to use the built-in default."
        }
      }
    }
  },
  "scripts": {
    "prebuild": "bun run scripts/prebuild.js",
    "compile": "bun run esbuild.config.js",
    "compile:watch": "bun run esbuild.config.js --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.js\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.js\" \"*.{json,md}\"",
    "type-check": "tsc --noEmit",
    "validate-skills": "bun run scripts/validate-skills.js",
    "pretest": "bun run scripts/prebuild.js && bun run esbuild.config.js && bun run type-check -p tsconfig.test.json",
    "test": "bun run ./test-out/test/runTests.js",
    "vscode:prepublish": "bun run scripts/prebuild.js && bun run esbuild.config.js --production",
    "package": "bun run vscode:prepublish && vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies",
    "clean": "rimraf dist assets test-out",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "glob": "^13.0.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "fuse.js": "^7.1.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "scripts/**/*.js": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
