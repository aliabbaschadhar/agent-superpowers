{
  "name": "agent-superpowers",
  "displayName": "AI Agent Superpowers",
  "description": "Browse, preview, and install 940+ AI agent skills for Claude Code, Gemini CLI, Cursor, GitHub Copilot, and more.",
  "version": "1.1.0",
  "publisher": "aliabbaschadhar",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/aliabbaschadhar/agent-superpowers"
  },
  "homepage": "https://github.com/aliabbaschadhar/agent-superpowers#readme",
  "bugs": {
    "url": "https://github.com/aliabbaschadhar/agent-superpowers/issues"
  },
  "keywords": [
    "claude-code",
    "cursor",
    "copilot",
    "ai-skills",
    "agentic",
    "skill-picker",
    "llm",
    "ai-agent",
    "gemini-cli"
  ],
  "categories": ["AI", "Other", "Snippets"],
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "commands": [
      {
        "command": "aiSkills.browse",
        "title": "Browse & Copy Skill ID",
        "category": "AI Skills"
      },
      {
        "command": "aiSkills.install",
        "title": "Install Skill to Agent",
        "category": "AI Skills"
      },
      {
        "command": "aiSkills.uninstall",
        "title": "Uninstall Skill",
        "category": "AI Skills",
        "icon": "$(trash)"
      },
      {
        "command": "aiSkills.preview",
        "title": "Preview Skill Content",
        "category": "AI Skills",
        "icon": "$(eye)"
      },
      {
        "command": "aiSkills.copyId",
        "title": "Copy Skill ID",
        "category": "AI Skills",
        "icon": "$(clippy)"
      },
      {
        "command": "aiSkills.installFromTree",
        "title": "Install from Sidebar",
        "category": "AI Skills",
        "icon": "$(cloud-download)"
      },
      {
        "command": "aiSkills.refreshTree",
        "title": "Refresh Skills Tree",
        "category": "AI Skills",
        "icon": "$(refresh)"
      },
      {
        "command": "aiSkills.bulkCopy",
        "title": "Bulk Copy Skill IDs to Clipboard",
        "category": "AI Skills",
        "icon": "$(copy)"
      },
      {
        "command": "aiSkills.installCategory",
        "title": "Install All in Category",
        "category": "AI Skills",
        "icon": "$(cloud-download)"
      },
      {
        "command": "aiSkills.installAll",
        "title": "Install All Skills",
        "category": "AI Skills",
        "icon": "$(cloud-download)"
      },
      {
        "command": "aiSkills.filterTree",
        "title": "Show Installed Skills Only",
        "category": "AI Skills",
        "icon": "$(filter)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiSkillsContainer",
          "title": "AI Agent Skills",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "aiSkillsContainer": [
        {
          "id": "aiSkillsTree",
          "name": "Skills",
          "type": "tree",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "aiSkills.filterTree",
          "when": "view == aiSkillsTree && !aiSkills.installedFilterActive",
          "group": "navigation@0"
        },
        {
          "command": "aiSkills.filterTree",
          "when": "view == aiSkillsTree && aiSkills.installedFilterActive",
          "group": "navigation@0"
        },
        {
          "command": "aiSkills.bulkCopy",
          "when": "view == aiSkillsTree",
          "group": "navigation@1"
        },
        {
          "command": "aiSkills.refreshTree",
          "when": "view == aiSkillsTree",
          "group": "navigation@2"
        },
        {
          "command": "aiSkills.installAll",
          "when": "view == aiSkillsTree",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "aiSkills.preview",
          "when": "view == aiSkillsTree && viewItem =~ /^skill(\\.favorited)?$/",
          "group": "inline@1"
        },
        {
          "command": "aiSkills.copyId",
          "when": "view == aiSkillsTree && viewItem =~ /^skill(\\.favorited)?$/",
          "group": "inline@2"
        },
        {
          "command": "aiSkills.installFromTree",
          "when": "view == aiSkillsTree && viewItem =~ /^skill(\\.favorited)?$/",
          "group": "inline@3"
        },
        {
          "command": "aiSkills.uninstall",
          "when": "view == aiSkillsTree && viewItem =~ /^skill(\\.favorited)?$/",
          "group": "inline@4"
        },
        {
          "command": "aiSkills.preview",
          "when": "view == aiSkillsTree && viewItem =~ /^skill-installed(\\.favorited)?$/",
          "group": "inline@1"
        },
        {
          "command": "aiSkills.copyId",
          "when": "view == aiSkillsTree && viewItem =~ /^skill-installed(\\.favorited)?$/",
          "group": "inline@2"
        },
        {
          "command": "aiSkills.installFromTree",
          "when": "view == aiSkillsTree && viewItem =~ /^skill-installed(\\.favorited)?$/",
          "group": "inline@3"
        },
        {
          "command": "aiSkills.uninstall",
          "when": "view == aiSkillsTree && viewItem =~ /^skill-installed(\\.favorited)?$/",
          "group": "inline@4"
        },
        {
          "command": "aiSkills.installCategory",
          "when": "view == aiSkillsTree && viewItem == category",
          "group": "inline@1"
        },
        {
          "command": "aiSkills.installAll",
          "when": "view == aiSkillsTree && viewItem == summary",
          "group": "inline@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "aiSkills.browse",
        "key": "ctrl+shift+/",
        "mac": "cmd+shift+/"
      }
    ],
    "configuration": {
      "title": "AI Agent Skills",
      "properties": {
        "aiSkills.defaultAgent": {
          "type": "string",
          "enum": ["auto", "claude", "gemini", "cursor", "copilot", "generic"],
          "default": "auto",
          "description": "Default install target. 'auto' detects from the running editor."
        },
        "aiSkills.claudeSkillsPath": {
          "type": "string",
          "default": "",
          "description": "Override directory for Claude Code skills. Leave empty for ~/.claude/skills."
        },
        "aiSkills.geminiSkillsPath": {
          "type": "string",
          "default": "",
          "description": "Override directory for Gemini CLI skills. Leave empty for ~/.gemini/skills."
        },
        "aiSkills.cursorScope": {
          "type": "string",
          "enum": ["project", "global"],
          "default": "project",
          "description": "Install Cursor rules at project (.cursor/rules/) or global level (~/.cursor/rules/)."
        },
        "aiSkills.confirmOverwrite": {
          "type": "boolean",
          "default": true,
          "description": "Ask before overwriting an already-installed skill file."
        },
        "aiSkills.showRiskBadge": {
          "type": "boolean",
          "default": true,
          "description": "Show risk level badge in the skill QuickPick list."
        },
        "aiSkills.autoPasteDelayMs": {
          "type": "number",
          "default": 80,
          "minimum": 0,
          "maximum": 2000,
          "description": "Delay in milliseconds between focus and paste when sending a skill ID to Claude Code chat. Increase on slower machines."
        },
        "aiSkills.localSkillsPath": {
          "type": "string",
          "default": "",
          "description": "Path to a local folder of custom skills (e.g. ~/my-ai-rules/). Each subfolder containing a SKILL.md is treated as a skill."
        },
        "aiSkills.remoteIndexUrl": {
          "type": "string",
          "default": "",
          "description": "Override the remote skills index URL (GitHub raw URL or Gist). Leave empty to use the built-in default."
        }
      }
    }
  },
  "scripts": {
    "prebuild": "bun run scripts/prebuild.js",
    "compile": "bun run esbuild.config.js",
    "compile:watch": "bun run esbuild.config.js --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "pretest": "bun run scripts/prebuild.js && bun run esbuild.config.js && bun run type-check -p tsconfig.test.json",
    "test": "bun run ./test-out/test/runTests.js",
    "vscode:prepublish": "bun run scripts/prebuild.js && bun run esbuild.config.js --production",
    "package": "bun run vscode:prepublish && vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies",
    "clean": "rimraf dist assets test-out"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.1",
    "glob": "^13.0.5",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "fuse.js": "^7.1.0"
  }
}
