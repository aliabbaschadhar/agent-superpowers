{
  // ─── GitHub Copilot — always inject .agent files into every request ───────
  "github.copilot.chat.codeGeneration.instructions": [
    {
      "file": ".agent/SYSTEM_PROMPT.md"
    },
    {
      "file": ".agent/AGENT_RULES.md"
    },
    {
      "file": ".agent/architecture.md"
    },
    {
      "file": ".agent/context.md"
    },
    {
      "file": ".agent/plan.md"
    },
    {
      "file": ".agent/prd.md"
    }
  ],
  // Include .agent files in every test-generation request too
  "github.copilot.chat.testGeneration.instructions": [
    {
      "file": ".agent/AGENT_RULES.md"
    },
    {
      "file": ".agent/architecture.md"
    }
  ],
  // Include .agent files in every code-review request
  "github.copilot.chat.reviewSelection.instructions": [
    {
      "file": ".agent/AGENT_RULES.md"
    }
  ],
  // Make .agent files discoverable in workspace search
  "files.exclude": {
    "**/.git": true
  },
  "search.exclude": {},
  // Editor comfort settings for markdown in .agent/
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "other": "off"
    }
  }
}